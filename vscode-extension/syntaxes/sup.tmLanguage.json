{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sup",
  "scopeName": "source.sup",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sup",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sup",
          "match": "\\b(if|else|elif|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.other.sup",
          "match": "\\b(func|var|const|import|from|class|struct|enum)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sup",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sup",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.sup",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sup",
              "match": "\\\\(n|t|r|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sup",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.sup",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.sup",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.other.sup" },
            "2": { "name": "entity.name.function.sup" }
          }
        },
        {
          "name": "entity.name.function.call.sup",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\("
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.sup",
          "match": "\\b(int|float|string|bool|void|list|dict)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sup",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.sup",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.assignment.sup",
          "match": "(=|\\+=|-=|\\*=|/=)"
        },
        {
          "name": "keyword.operator.arithmetic.sup",
          "match": "(\\+\\+|--|\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.sup",
          "match": "->"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.sup",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    }
  }
}
